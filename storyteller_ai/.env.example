# Storyteller AI Agent - Development Environment Configuration

# ============================================
# LLM PROVIDER SELECTION
# ============================================
# Choose your LLM provider: openai, anthropic, ollama, or mock
# For offline/local operation, use: LLM_PROVIDER=ollama
LLM_PROVIDER=ollama

# ============================================
# OPENAI CONFIGURATION (if using OpenAI provider)
# ============================================
# OPENAI_API_KEY=sk-your-api-key-here
# LLM_MODEL=gpt-4o-mini

# ============================================
# ANTHROPIC CONFIGURATION (if using Anthropic provider)
# ============================================
# ANTHROPIC_API_KEY=your-anthropic-api-key
# LLM_MODEL=claude-3-sonnet

# ============================================
# OLLAMA CONFIGURATION (for local offline use)
# ============================================
# Ollama server URL (default localhost with port 11434)
OLLAMA_URL=http://127.0.0.1:11434

# Ollama model name - MUST match a model you've pulled locally
# Recommended models:
#   - llama2:7b        (general purpose, good quality)
#   - mistral:7b       (faster inference, good balance)
#   - neural-chat:7b   (optimized for conversations)
#   - dolphin-mixtral  (creative writing, larger 47GB)
OLLAMA_MODEL=llama2:7b

# ============================================
# SETUP INSTRUCTIONS FOR OLLAMA
# ============================================
# To use Ollama:
#
# 1. Install Ollama from https://ollama.ai
#
# 2. Start Ollama server:
#    ollama serve
#
# 3. Download a model (in another terminal):
#    ollama pull llama2:7b
#
# 4. Update this file:
#    - Set LLM_PROVIDER=ollama
#    - Set OLLAMA_MODEL=llama2:7b
#    - Leave OPENAI_API_KEY and ANTHROPIC_API_KEY empty
#
# 5. Run your application normally
#    Your app will now run completely offline!
#
# For automated setup, run:
#   .\setup_ollama.ps1 -Action install -Model llama2:7b
