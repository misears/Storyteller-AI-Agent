# Local development environment variables

# Choose one provider:
# LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic
# LLM_PROVIDER=ollama
# LLM_PROVIDER=mock

LLM_PROVIDER=mock

# If using OpenAI:
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# If using Anthropic:
# ANTHROPIC_API_KEY=...
# LLM_MODEL=claude-3.0

# If using Ollama:
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama2
# LLM_MODEL can also be set to your Ollama model name
